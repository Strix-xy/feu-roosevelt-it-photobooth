# Vercel Blob — required for QR code uploads (unique link per session)
# Create a Blob store in the Vercel dashboard (Storage → Blob → Public),
# then either link it to this project (auto-injects the token) or paste it here.
# Locally: run `npx vercel env pull` after linking the project.
BLOB_READ_WRITE_TOKEN=

# Secures /api/cron/cleanup (Vercel sends Authorization: Bearer <CRON_SECRET>).
# Add in Vercel → Project → Settings → Environment Variables (Production).
# Use a long random string (16+ chars). Required for retention cleanup to run.
CRON_SECRET=

# How long to keep photostrips in Blob before the daily cleanup deletes them.
# Default: 48. Guests must download before this window ends.
# BLOB_RETENTION_HOURS=48
